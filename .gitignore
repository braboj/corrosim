# Byte-compiled / caches
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# Coverage (pytest-cov)
.coverage
.coverage.*
coverage.xml
htmlcov/

# Virtual envs
.venv/
venv/
env/

# Tool / run outputs
*.html
# the curated multiscale report bundle is tracked (report.html + report.docx +
# figures/ + tables/; see runs/make_report.py)
!report/report.html
*.cif
*.cube
*_slab.xyz
results.csv
!examples/*.csv

# QC scratch dirs
orca_*/
g16_*/
*.gbw
*.chk
*.log

# OS / editor
.DS_Store
.idea/
.vscode/
~$*.docx        # Word lock/owner files

# Local-only notes (kept with the project, never pushed)
*.local.md
docs/local/

# loose run-output figures in repo root (report/figures/ holds the curated set)
/*.png

# Volumetric cubes: large, regenerable (make_cubes) — never tracked
cubes/
